{
	"name": "@lesjoursfr/edith",
	"version": "4.1.2",
	"description": "Simple WYSIWYG editor.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lesjoursfr/edith.git"
	},
	"homepage": "https://github.com/lesjoursfr/edith#readme",
	"bugs": {
		"url": "https://github.com/lesjoursfr/edith/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": "22.x || 24.x || 26.x"
	},
	"browserslist": [
		"> 1%",
		"last 3 versions",
		"not dead"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"scripts": {
		"freshlock": "rm -rf node_modules/ && rm .yarn/install-state.gz && rm yarn.lock && yarn",
		"eslint-check": "eslint",
		"eslint-fix": "eslint --fix",
		"stylelint-check": "stylelint **/*.scss",
		"stylelint-fix": "stylelint **/*.scss --fix",
		"prettier-check": "prettier --check .",
		"prettier-fix": "prettier --write .",
		"test": "NODE_OPTIONS='--loader=ts-node/esm' mocha",
		"build-esm": "tsc && node assets.js",
		"build-browser": "webpack --mode production --config ./server/webpack.config.js --progress",
		"build": "npm run build-esm && npm run build-browser",
		"builddeps": "webpack --mode production --config server/deps/codemirror.webpack.js --progress",
		"server": "webpack serve --mode development --config ./server/webpack.config.js --hot --open"
	},
	"keywords": [
		"WYSIWYG",
		"editor"
	],
	"dependencies": {
		"@lesjoursfr/browser-tools": "^3.1.4",
		"dompurify": "^3.4.10"
	},
	"devDependencies": {
		"@babel/core": "8.0.0",
		"@babel/preset-env": "8.0.0",
		"@codemirror/lang-html": "6.4.11",
		"@eslint/js": "10.0.1",
		"@fortawesome/fontawesome-free": "7.2.0",
		"@popperjs/core": "2.11.8",
		"@tsconfig/next": "2.0.6",
		"@types/babel__core": "7.20.5",
		"@types/babel__preset-env": "7.10.0",
		"@types/color": "4.2.1",
		"@types/jsdom": "28.0.3",
		"@types/mocha": "10.0.10",
		"@types/node": "24.13.2",
		"@types/webpack-env": "1.18.8",
		"babel-loader": "10.1.1",
		"codemirror": "6.0.2",
		"css-loader": "7.1.4",
		"cssnano": "8.0.2",
		"eslint": "10.5.0",
		"eslint-config-prettier": "10.1.8",
		"fs-extra": "11.3.5",
		"globals": "17.6.0",
		"jsdom": "29.1.1",
		"mini-css-extract-plugin": "2.10.2",
		"minimizer-webpack-plugin": "5.6.1",
		"mocha": "11.7.6",
		"postcss": "8.5.15",
		"prettier": "3.8.4",
		"sass": "1.101.0",
		"sass-loader": "17.0.0",
		"stylelint": "17.13.0",
		"stylelint-config-standard-scss": "17.0.0",
		"ts-loader": "9.6.0",
		"ts-node": "10.9.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.61.0",
		"webpack": "5.107.2",
		"webpack-cli": "7.0.3",
		"webpack-dev-server": "5.2.5"
	},
	"peerDependencies": {
		"@codemirror/lang-html": "^6.4.11",
		"@fortawesome/fontawesome-free": "^7.2.0",
		"@popperjs/core": "^2.11.8",
		"codemirror": "^6.0.2"
	},
	"dependenciesMeta": {
		"@parcel/watcher": {
			"built": true
		}
	},
	"packageManager": "yarn@4.17.0"
}
